{
  "name": "uma-tools",
  "version": "0.0.1",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "update:data": "node scripts/update-data.mjs",
    "build:umalator-global": "npm run update:data && cd umalator-global && node build.mjs",
    "electron:set-icon": "node electron/set-icon.mjs",
    "electron:start": "npm run build:umalator-global && electron electron/main.js",
    "electron:pack": "npm run build:umalator-global && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win dir --x64 && npm run electron:set-icon",
    "electron:dist": "npm run build:umalator-global && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis --x64"
  },
  "author": "pecan",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "electron": "^37.5.1",
    "electron-builder": "^26.0.12",
    "rcedit": "^5.0.2",
    "commander": "^13.1.0",
    "esbuild": "^0.19.5"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.2",
    "d3": "^7.9.0",
    "immutable": "^5.0.3",
    "lucide-preact": "^0.562.0",
    "posthog-js": "^1.257.0",
    "prando": "^6.0.1",
    "preact": "^10.18.1",
    "preact-i18n": "^2.4.0-preactx",
    "unassert-cli": "github:unassert-js/unassert-cli"
  },
  "build": {
    "appId": "com.umatools.umalator",
    "productName": "Umalator",
    "directories": {
      "output": "release-package"
    },
    "files": [
      "electron/**/*",
      "umalator-global/**/*",
      "uma-skill-tools/data/**/*",
      "icons/**/*",
      "fonts/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
